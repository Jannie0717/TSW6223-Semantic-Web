@prefix ex: <http://example.org/education#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Ontology: Semantic Course and Career Recommendation System
#################################################################

ex:EducationOntology a owl:Ontology ;
    rdfs:label "Semantic Education Ontology" ;
    rdfs:comment "Ontology for connecting student skills, interests, courses and career paths." .

#################################################################
# Classes
#################################################################

ex:Student a owl:Class ;
    rdfs:label "Student" .

ex:Course a owl:Class ;
    rdfs:label "Course" .

ex:Skill a owl:Class ;
    rdfs:label "Skill" .

ex:Career a owl:Class ;
    rdfs:label "Career" .

ex:Interest a owl:Class ;
    rdfs:label "Interest" .

#################################################################
# Object Properties
#################################################################

ex:hasSkill a owl:ObjectProperty ;
    rdfs:domain ex:Student ;
    rdfs:range ex:Skill ;
    rdfs:label "has skill" .

ex:interestedIn a owl:ObjectProperty ;
    rdfs:domain ex:Student ;
    rdfs:range ex:Interest ;
    rdfs:label "interested in" .

ex:requiresSkill a owl:ObjectProperty ;
    rdfs:domain ex:Career ;
    rdfs:range ex:Skill ;
    rdfs:label "requires skill" .

ex:teachesSkill a owl:ObjectProperty ;
    rdfs:domain ex:Course ;
    rdfs:range ex:Skill ;
    rdfs:label "teaches skill" .

ex:relatedToInterest a owl:ObjectProperty ;
    rdfs:domain ex:Career ;
    rdfs:range ex:Interest ;
    rdfs:label "related to interest" .

ex:hasPrerequisiteSkill a owl:ObjectProperty ;
    rdfs:domain ex:Course ;
    rdfs:range ex:Skill ;
    rdfs:label "has prerequisite skill" .

ex:possibleCareer a owl:ObjectProperty ;
    rdfs:domain ex:Student ;
    rdfs:range ex:Career ;
    rdfs:label "possible career" ;
    rdfs:comment "Inferred property: student may choose this career based on selected interest." .

ex:recommendedCourse a owl:ObjectProperty ;
    rdfs:domain ex:Student ;
    rdfs:range ex:Course ;
    rdfs:label "recommended course" ;
    rdfs:comment "Inferred property: course is recommended because it teaches missing skills." .

ex:supportsCareer a owl:ObjectProperty ;
    rdfs:domain ex:Course ;
    rdfs:range ex:Career ;
    rdfs:label "supports career" ;
    rdfs:comment "Inferred property: course supports a career if it teaches a skill required by the career." .

#################################################################
# Datatype Properties
#################################################################

ex:difficulty a owl:DatatypeProperty ;
    rdfs:domain ex:Course ;
    rdfs:range xsd:string ;
    rdfs:label "difficulty" .

ex:creditHour a owl:DatatypeProperty ;
    rdfs:domain ex:Course ;
    rdfs:range xsd:integer ;
    rdfs:label "credit hour" .

ex:description a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "description" .

#################################################################
# Interests
#################################################################

ex:ArtificialIntelligence a ex:Interest ;
    rdfs:label "Artificial Intelligence" .

ex:DataScience a ex:Interest ;
    rdfs:label "Data Science" .

ex:Cybersecurity a ex:Interest ;
    rdfs:label "Cybersecurity" .

ex:WebDevelopment a ex:Interest ;
    rdfs:label "Web Development" .

#################################################################
# Skills
#################################################################

ex:Python a ex:Skill ; rdfs:label "Python Programming" .
ex:Statistics a ex:Skill ; rdfs:label "Statistics" .
ex:MachineLearning a ex:Skill ; rdfs:label "Machine Learning" .
ex:DataVisualization a ex:Skill ; rdfs:label "Data Visualization" .
ex:DeepLearning a ex:Skill ; rdfs:label "Deep Learning" .
ex:Database a ex:Skill ; rdfs:label "Database Management" .
ex:Networking a ex:Skill ; rdfs:label "Computer Networking" .
ex:SecurityFundamentals a ex:Skill ; rdfs:label "Security Fundamentals" .
ex:HTMLCSS a ex:Skill ; rdfs:label "HTML and CSS" .
ex:JavaScript a ex:Skill ; rdfs:label "JavaScript" .
ex:BackendProgramming a ex:Skill ; rdfs:label "Backend Programming" .
ex:Algorithms a ex:Skill ; rdfs:label "Algorithms" .
ex:CriticalThinking a ex:Skill ; rdfs:label "Critical Thinking" .

#################################################################
# Careers
#################################################################

ex:DataAnalyst a ex:Career ;
    rdfs:label "Data Analyst" ;
    ex:description "Uses data analysis and visualization to support decision-making." ;
    ex:relatedToInterest ex:DataScience ;
    ex:requiresSkill ex:Python, ex:Statistics, ex:DataVisualization, ex:Database .

ex:DataScientist a ex:Career ;
    rdfs:label "Data Scientist" ;
    ex:description "Builds analytical and machine learning models from data." ;
    ex:relatedToInterest ex:DataScience, ex:ArtificialIntelligence ;
    ex:requiresSkill ex:Python, ex:Statistics, ex:MachineLearning, ex:DataVisualization, ex:Database .

ex:AIEngineer a ex:Career ;
    rdfs:label "AI Engineer" ;
    ex:description "Develops artificial intelligence models and intelligent applications." ;
    ex:relatedToInterest ex:ArtificialIntelligence ;
    ex:requiresSkill ex:Python, ex:MachineLearning, ex:DeepLearning, ex:Algorithms .

ex:CybersecurityAnalyst a ex:Career ;
    rdfs:label "Cybersecurity Analyst" ;
    ex:description "Protects systems and investigates security threats." ;
    ex:relatedToInterest ex:Cybersecurity ;
    ex:requiresSkill ex:Networking, ex:SecurityFundamentals, ex:Python, ex:CriticalThinking .

ex:WebDeveloper a ex:Career ;
    rdfs:label "Web Developer" ;
    ex:description "Builds and maintains websites and web applications." ;
    ex:relatedToInterest ex:WebDevelopment ;
    ex:requiresSkill ex:HTMLCSS, ex:JavaScript, ex:BackendProgramming, ex:Database .

#################################################################
# Courses
#################################################################

ex:IntroPython a ex:Course ;
    rdfs:label "Introduction to Python Programming" ;
    ex:description "Covers Python syntax, variables, loops, functions and basic problem solving." ;
    ex:teachesSkill ex:Python ;
    ex:difficulty "Beginner" ;
    ex:creditHour 3 .

ex:AppliedStatistics a ex:Course ;
    rdfs:label "Applied Statistics" ;
    ex:description "Introduces statistical concepts used in data analysis and research." ;
    ex:teachesSkill ex:Statistics ;
    ex:difficulty "Beginner" ;
    ex:creditHour 3 .

ex:DataVisualizationCourse a ex:Course ;
    rdfs:label "Data Visualization" ;
    ex:description "Teaches charting, dashboard design and visual communication of data." ;
    ex:teachesSkill ex:DataVisualization ;
    ex:hasPrerequisiteSkill ex:Python ;
    ex:difficulty "Intermediate" ;
    ex:creditHour 3 .

ex:DatabaseSystems a ex:Course ;
    rdfs:label "Database Systems" ;
    ex:description "Covers database design, SQL, data modelling and information management." ;
    ex:teachesSkill ex:Database ;
    ex:difficulty "Beginner" ;
    ex:creditHour 3 .

ex:MachineLearningCourse a ex:Course ;
    rdfs:label "Machine Learning" ;
    ex:description "Introduces supervised and unsupervised learning algorithms." ;
    ex:teachesSkill ex:MachineLearning ;
    ex:hasPrerequisiteSkill ex:Python, ex:Statistics ;
    ex:difficulty "Intermediate" ;
    ex:creditHour 3 .

ex:DeepLearningCourse a ex:Course ;
    rdfs:label "Deep Learning" ;
    ex:description "Covers neural networks and deep learning applications." ;
    ex:teachesSkill ex:DeepLearning ;
    ex:hasPrerequisiteSkill ex:MachineLearning ;
    ex:difficulty "Advanced" ;
    ex:creditHour 3 .

ex:AlgorithmDesign a ex:Course ;
    rdfs:label "Algorithm Design" ;
    ex:description "Covers algorithmic thinking, complexity and problem-solving techniques." ;
    ex:teachesSkill ex:Algorithms ;
    ex:hasPrerequisiteSkill ex:Python ;
    ex:difficulty "Intermediate" ;
    ex:creditHour 3 .

ex:NetworkFundamentals a ex:Course ;
    rdfs:label "Network Fundamentals" ;
    ex:description "Introduces computer networks, protocols and network troubleshooting." ;
    ex:teachesSkill ex:Networking ;
    ex:difficulty "Beginner" ;
    ex:creditHour 3 .

ex:CyberSecurityBasics a ex:Course ;
    rdfs:label "Cybersecurity Basics" ;
    ex:description "Covers cyber threats, security principles and basic protection methods." ;
    ex:teachesSkill ex:SecurityFundamentals ;
    ex:hasPrerequisiteSkill ex:Networking ;
    ex:difficulty "Intermediate" ;
    ex:creditHour 3 .

ex:CriticalThinkingCourse a ex:Course ;
    rdfs:label "Critical Thinking and Problem Solving" ;
    ex:description "Develops logical reasoning and structured problem-solving skills." ;
    ex:teachesSkill ex:CriticalThinking ;
    ex:difficulty "Beginner" ;
    ex:creditHour 2 .

ex:WebDesign a ex:Course ;
    rdfs:label "Web Design with HTML and CSS" ;
    ex:description "Teaches static website creation using HTML and CSS." ;
    ex:teachesSkill ex:HTMLCSS ;
    ex:difficulty "Beginner" ;
    ex:creditHour 3 .

ex:JavaScriptDevelopment a ex:Course ;
    rdfs:label "JavaScript Development" ;
    ex:description "Covers interactive web programming using JavaScript." ;
    ex:teachesSkill ex:JavaScript ;
    ex:hasPrerequisiteSkill ex:HTMLCSS ;
    ex:difficulty "Intermediate" ;
    ex:creditHour 3 .

ex:BackendWebProgramming a ex:Course ;
    rdfs:label "Backend Web Programming" ;
    ex:description "Covers server-side logic, APIs and database connection for web systems." ;
    ex:teachesSkill ex:BackendProgramming ;
    ex:hasPrerequisiteSkill ex:JavaScript, ex:Database ;
    ex:difficulty "Intermediate" ;
    ex:creditHour 3 .
