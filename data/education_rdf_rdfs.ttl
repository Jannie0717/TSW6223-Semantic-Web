@prefix ex: <http://example.org/education#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Solution 1: Semantic Course Recommendation System
# Selected SWT focus: Category 2 only - RDF, RDFS and SPARQL
# Removed: Career Path / Skill Gap Analysis
#################################################################

#################################################################
# RDFS Classes
#################################################################

ex:Student a rdfs:Class ;
    rdfs:label "Student" ;
    rdfs:comment "A learner who selects a learning interest area." .

ex:Course a rdfs:Class ;
    rdfs:label "Course" ;
    rdfs:comment "An education subject or module that teaches one or more skills." .

ex:Skill a rdfs:Class ;
    rdfs:label "Skill" ;
    rdfs:comment "A competency that can be taught by courses." .

ex:Interest a rdfs:Class ;
    rdfs:label "Interest" ;
    rdfs:comment "A student's learning interest area." .

#################################################################
# RDF Properties with RDFS domain and range
#################################################################

ex:interestedIn a rdf:Property ;
    rdfs:label "interested in" ;
    rdfs:domain ex:Student ;
    rdfs:range ex:Interest .

ex:teachesSkill a rdf:Property ;
    rdfs:label "teaches skill" ;
    rdfs:domain ex:Course ;
    rdfs:range ex:Skill .

ex:relatedToInterest a rdf:Property ;
    rdfs:label "related to interest" ;
    rdfs:domain ex:Course ;
    rdfs:range ex:Interest .

ex:hasPrerequisiteSkill a rdf:Property ;
    rdfs:label "has prerequisite skill" ;
    rdfs:domain ex:Course ;
    rdfs:range ex:Skill .

ex:description a rdf:Property ;
    rdfs:label "description" .

ex:skillCategory a rdf:Property ;
    rdfs:label "skill category" ;
    rdfs:domain ex:Skill .

ex:difficulty a rdf:Property ;
    rdfs:label "difficulty" ;
    rdfs:domain ex:Course .

ex:creditHour a rdf:Property ;
    rdfs:label "credit hour" ;
    rdfs:domain ex:Course .

#################################################################
# Interests
#################################################################

ex:ArtificialIntelligence a ex:Interest ;
    rdfs:label "Artificial Intelligence" ;
    ex:description "Interest in intelligent systems, automation and machine learning." .

ex:DataScience a ex:Interest ;
    rdfs:label "Data Science" ;
    ex:description "Interest in data analysis, statistics and data-driven decision making." .

ex:SoftwareDevelopment a ex:Interest ;
    rdfs:label "Software Development" ;
    ex:description "Interest in designing and building software systems." .

ex:Cybersecurity a ex:Interest ;
    rdfs:label "Cybersecurity" ;
    ex:description "Interest in protecting systems, networks and data." .

ex:WebDevelopmentInterest a ex:Interest ;
    rdfs:label "Web Development" ;
    ex:description "Interest in creating websites and web applications." .

#################################################################
# Skills
#################################################################

ex:Python a ex:Skill ;
    rdfs:label "Python Programming" ;
    ex:skillCategory "Programming" .

ex:SQL a ex:Skill ;
    rdfs:label "SQL" ;
    ex:skillCategory "Database" .

ex:Statistics a ex:Skill ;
    rdfs:label "Statistics" ;
    ex:skillCategory "Data Analysis" .

ex:MachineLearning a ex:Skill ;
    rdfs:label "Machine Learning" ;
    ex:skillCategory "Artificial Intelligence" .

ex:DeepLearning a ex:Skill ;
    rdfs:label "Deep Learning" ;
    ex:skillCategory "Artificial Intelligence" .

ex:Algorithms a ex:Skill ;
    rdfs:label "Algorithms" ;
    ex:skillCategory "Programming" .

ex:DataVisualization a ex:Skill ;
    rdfs:label "Data Visualization" ;
    ex:skillCategory "Data Analysis" .

ex:Database a ex:Skill ;
    rdfs:label "Database Management" ;
    ex:skillCategory "Database" .

ex:Networking a ex:Skill ;
    rdfs:label "Computer Networking" ;
    ex:skillCategory "Networking" .

ex:SecurityFundamentals a ex:Skill ;
    rdfs:label "Security Fundamentals" ;
    ex:skillCategory "Cybersecurity" .

ex:CriticalThinking a ex:Skill ;
    rdfs:label "Critical Thinking" ;
    ex:skillCategory "Essential Skill" .

ex:ProblemSolving a ex:Skill ;
    rdfs:label "Problem Solving" ;
    ex:skillCategory "Essential Skill" .

ex:HTMLCSS a ex:Skill ;
    rdfs:label "HTML and CSS" ;
    ex:skillCategory "Web Development" .

ex:JavaScript a ex:Skill ;
    rdfs:label "JavaScript" ;
    ex:skillCategory "Web Development" .

ex:BackendProgramming a ex:Skill ;
    rdfs:label "Backend Programming" ;
    ex:skillCategory "Web Development" .

ex:WebDevelopmentSkill a ex:Skill ;
    rdfs:label "Web Development" ;
    ex:skillCategory "Web Development" .

#################################################################
# Courses
#################################################################

ex:IntroPython a ex:Course ;
    rdfs:label "Introduction to Python Programming" ;
    ex:description "Introduces Python syntax, programming logic and basic problem solving." ;
    ex:relatedToInterest ex:ArtificialIntelligence, ex:DataScience, ex:SoftwareDevelopment ;
    ex:teachesSkill ex:Python ;
    ex:difficulty "Beginner" ;
    ex:creditHour 3 .

ex:DatabaseSystems a ex:Course ;
    rdfs:label "Database Systems" ;
    ex:description "Covers database design, SQL queries and relational data management." ;
    ex:relatedToInterest ex:DataScience, ex:SoftwareDevelopment, ex:WebDevelopmentInterest ;
    ex:teachesSkill ex:SQL, ex:Database ;
    ex:difficulty "Beginner" ;
    ex:creditHour 3 .

ex:StatisticsAnalytics a ex:Course ;
    rdfs:label "Statistics for Data Analytics" ;
    ex:description "Covers probability, descriptive statistics and basic statistical analysis." ;
    ex:relatedToInterest ex:DataScience, ex:ArtificialIntelligence ;
    ex:teachesSkill ex:Statistics ;
    ex:difficulty "Beginner" ;
    ex:creditHour 3 .

ex:MachineLearningCourse a ex:Course ;
    rdfs:label "Machine Learning" ;
    ex:description "Introduces supervised learning, model evaluation and machine learning workflows." ;
    ex:relatedToInterest ex:ArtificialIntelligence, ex:DataScience ;
    ex:teachesSkill ex:MachineLearning ;
    ex:hasPrerequisiteSkill ex:Python, ex:Statistics ;
    ex:difficulty "Intermediate" ;
    ex:creditHour 4 .

ex:DeepLearningCourse a ex:Course ;
    rdfs:label "Deep Learning" ;
    ex:description "Introduces neural networks and deep learning applications." ;
    ex:relatedToInterest ex:ArtificialIntelligence ;
    ex:teachesSkill ex:DeepLearning ;
    ex:hasPrerequisiteSkill ex:Python, ex:MachineLearning ;
    ex:difficulty "Advanced" ;
    ex:creditHour 4 .

ex:AlgorithmDesign a ex:Course ;
    rdfs:label "Algorithm Design" ;
    ex:description "Covers algorithmic thinking, data structures and computational problem solving." ;
    ex:relatedToInterest ex:ArtificialIntelligence, ex:SoftwareDevelopment ;
    ex:teachesSkill ex:Algorithms, ex:ProblemSolving ;
    ex:difficulty "Intermediate" ;
    ex:creditHour 3 .

ex:DataVisualizationCourse a ex:Course ;
    rdfs:label "Data Visualization" ;
    ex:description "Teaches dashboards, charts and visual communication of data." ;
    ex:relatedToInterest ex:DataScience ;
    ex:teachesSkill ex:DataVisualization ;
    ex:hasPrerequisiteSkill ex:Statistics ;
    ex:difficulty "Intermediate" ;
    ex:creditHour 3 .

ex:NetworkingCourse a ex:Course ;
    rdfs:label "Computer Networking" ;
    ex:description "Explains network models, protocols and network communication." ;
    ex:relatedToInterest ex:Cybersecurity ;
    ex:teachesSkill ex:Networking ;
    ex:difficulty "Beginner" ;
    ex:creditHour 3 .

ex:CyberSecurityBasics a ex:Course ;
    rdfs:label "Cybersecurity Fundamentals" ;
    ex:description "Covers basic cyber threats, protection concepts and security practices." ;
    ex:relatedToInterest ex:Cybersecurity ;
    ex:teachesSkill ex:SecurityFundamentals ;
    ex:hasPrerequisiteSkill ex:Networking ;
    ex:difficulty "Intermediate" ;
    ex:creditHour 3 .

ex:CriticalThinkingCourse a ex:Course ;
    rdfs:label "Critical Thinking and Problem Solving" ;
    ex:description "Improves reasoning, analysis and decision-making skills." ;
    ex:relatedToInterest ex:Cybersecurity, ex:SoftwareDevelopment, ex:DataScience ;
    ex:teachesSkill ex:CriticalThinking, ex:ProblemSolving ;
    ex:difficulty "Beginner" ;
    ex:creditHour 2 .

ex:WebDesign a ex:Course ;
    rdfs:label "Web Design" ;
    ex:description "Introduces HTML, CSS and responsive website layout." ;
    ex:relatedToInterest ex:WebDevelopmentInterest, ex:SoftwareDevelopment ;
    ex:teachesSkill ex:HTMLCSS, ex:WebDevelopmentSkill ;
    ex:difficulty "Beginner" ;
    ex:creditHour 3 .

ex:JavaScriptDevelopment a ex:Course ;
    rdfs:label "JavaScript Development" ;
    ex:description "Teaches interactive web application development using JavaScript." ;
    ex:relatedToInterest ex:WebDevelopmentInterest, ex:SoftwareDevelopment ;
    ex:teachesSkill ex:JavaScript ;
    ex:hasPrerequisiteSkill ex:HTMLCSS ;
    ex:difficulty "Intermediate" ;
    ex:creditHour 3 .

ex:BackendWebProgramming a ex:Course ;
    rdfs:label "Backend Web Programming" ;
    ex:description "Covers server-side programming, APIs and backend application logic." ;
    ex:relatedToInterest ex:WebDevelopmentInterest, ex:SoftwareDevelopment ;
    ex:teachesSkill ex:BackendProgramming ;
    ex:hasPrerequisiteSkill ex:Python, ex:Database ;
    ex:difficulty "Intermediate" ;
    ex:creditHour 3 .
